# Example environment file for local development — DO NOT commit secrets.
# Copy this to .env.local and fill in values that point to your remote/staging project.

# Public Supabase (frontend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side / admin only (DO NOT commit real values)
# SUPABASE_SERVICE_ROLE_KEY gives admin/postgres access and should be kept secret.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONNECTION_STRING=
SUPABASE_PGCRYPTO_KEY=

# ABR (ABN) Lookup
ABR_GUID=
ABR_API_KEY=

# Optional LLM / AI keys (leave blank if you don't use AI features locally)
# Current runtime expects a z.ai-compatible endpoint and key.
LLM_PROVIDER=zai
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
LLM_DEFAULT_MODEL=glm-4.6

# AI Control & Automation Modes
# Values: disabled | shadow | live
# - disabled: AI completely off, uses deterministic fallbacks only
# - shadow: AI runs but decisions are logged only (not applied)
# - live: AI decisions are applied in production
AI_GLOBAL_MODE=live
TRIAGE_AI_MODE=          # Overrides AI_GLOBAL_MODE for emergency triage
DIGEST_AI_MODE=          # Overrides AI_GLOBAL_MODE for ops digest
VERIFICATION_AI_MODE=    # Overrides AI_GLOBAL_MODE for resource verification
MODERATION_AI_MODE=      # Overrides AI_GLOBAL_MODE for review moderation
OWNER_ACTION_AI_MODE=    # Overrides AI_GLOBAL_MODE for owner action guidance

# Optional infrastructure / features
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
RESEND_API_KEY=
SENTRY_DSN=
CRON_SECRET=             # Secret for authenticating Vercel cron requests

# Optional ops / safety toggles
AUTO_APPLY=false
SCRAPER_ENABLED=false
